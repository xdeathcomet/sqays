-- Helper Functions
local function getSpeed(val) 
	return tonumber(string.match(val or "", "[%d%.]+")) or 1 
end

local function walkTo(position, timeout)
	timeout = timeout or 6
	local char = LocalPlayer.Character
	if not char then return end

	local humanoid = char:FindFirstChild("Humanoid")
	local root = char:FindFirstChild("HumanoidRootPart")
	if not humanoid or not root then return end

	humanoid:MoveTo(position)

	local start = tick()
	while (root.Position - position).Magnitude > 4 and (tick() - start) < timeout do
		task.wait(0.1)
	end
end

local function savePreset()
	local data = {
		UpgradeSpeed = _G.UpgradeSpeed,
		TapSpeed = _G.TapSpeed,
		AscendSpeed = _G.AscendSpeed,
		RuneSpeed = _G.RuneSpeed,
		MineSpeed = _G.MineSpeed,
		SellSpeed = _G.SellSpeed,
		FruitTPSpeed = _G.FruitTPSpeed,
		TreeTPSpeed = _G.TreeTPSpeed,
		TreeWalkSpeed = _G.TreeWalkSpeed,
		AutoSword = _G.AutoSword,
		AutoTap = _G.AutoTap,
		AutoAscend = _G.AutoAscend,
		AutoSac = _G.AutoSac,
		AutoPickaxe = _G.AutoPickaxe,
		AutoSell = _G.AutoSell,
		TPFarm = _G.TPFarm,
		WalkFarm = _G.WalkFarm,
		TPChop = _G.TPChop,
		WalkChop = _G.WalkChop,
		AutoAFK = _G.AutoAFK
	}
	for k, v in pairs(_G) do
		if string.find(k, "Toggle") or string.find(k, "AutoMine") or string.find(k, "SmartMine") or string.find(k, "AutoRune") then
			data[k] = v
		end
	end
	writefile(FILE_NAME, HttpService:JSONEncode(data))
end

local function loadPreset()
	if isfile(FILE_NAME) then
		local success, decoded = pcall(function()
			return HttpService:JSONDecode(readfile(FILE_NAME))
		end)
		if success and type(decoded) == "table" then
			for k, v in pairs(decoded) do
				_G[k] = v
			end
			return true
		end
	end
	return false
end

local function deletePreset()
	if isfile(FILE_NAME) then
		delfile(FILE_NAME)
	end
end

if isfile(FILE_NAME) then
	loadPreset()
end

