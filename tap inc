local function createOreToggle(name, orePrefix)
	MiningTab:CreateToggle({
		Name = "Auto Mine " .. name,
		Callback = function(v)
			_G["AutoMine" .. name] = v
			if v then
				task.spawn(function()
					while _G["AutoMine" .. name] do
						local OreFolder = Workspace:FindFirstChild("Ores")
						if OreFolder then
							for _, ore in ipairs(OreFolder:GetChildren()) do
								if not _G["AutoMine" .. name] then break end
								if ore.Name:find(orePrefix) then
									local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
									if root then
										root.CFrame = ore:GetPivot()
										pcall(function() MineRemote:InvokeServer(ore.Name) end)
										task.wait(_G.MineSpeed)
									end
								end
							end
						end
						task.wait(0.1)
					end
				end)
			end
		end
	})
end

