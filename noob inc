-- ===== TRIAL SYSTEM =====
local function teleportTo(pos)
    local ok, result = pcall(function()
        local char = LP.Character
        if not char then return false end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return false end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.PlatformStand = false; hum.Sit = false end
        hrp.CFrame = CFrame.new(pos)
        hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        task.wait(0.05)
        hrp.CFrame = CFrame.new(pos)
        hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        return true
    end)
    if not ok then warn("[TELEPORT] Exception: " .. tostring(result)); return false end
    return result
end
local function getCountdownLabel(diff)
    local obj = WS
    for _, name in ipairs(Trials[diff].path) do if obj then obj = obj:FindFirstChild(name) end end
    if obj and obj:IsA("TextLabel") then return obj end
    for _, v in ipairs(WS:GetDescendants()) do
        if v:IsA("TextLabel") and v.Name:lower():find("timer") and v.Text:lower():find("trial") then return v end
    end
    return nil
end
local function parseCountdown(text)
    if not text then return 0 end
    local min = tonumber(text:match("(%d+)m")) or 0
    local sec = tonumber(text:match("(%d+)s")) or 0
    return min * 60 + sec
end
local function findTrialMob(room)
    if not room then return nil, nil, nil end
    local mobsFolder = room:FindFirstChild("Mobs")
    if not mobsFolder then return nil, nil, nil end
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil, nil, nil end
    local best, bestHRP, bestHum, bestDist = nil, nil, nil, math.huge
    for _, mob in ipairs(mobsFolder:GetChildren()) do
        if mob:IsA("Model") then
            local hum = nil
            for _, d in ipairs(mob:GetDescendants()) do
                if d:IsA("Humanoid") then hum = d; break end
            end
            if hum and hum.Health > 0 then
                local root = mob:FindFirstChild("HumanoidRootPart") or mob.PrimaryPart
                if not root then
                    for _, d in ipairs(mob:GetDescendants()) do
                        if d:IsA("BasePart") and d.Name == "HumanoidRootPart" then root = d; break end
                    end
                end
                if root and root:IsA("BasePart") then
                    local d = (hrp.Position - root.Position).Magnitude
                    if d < bestDist then bestDist = d; best = mob; bestHRP = root; bestHum = hum end
                end
            end
        end
    end
    return best, bestHRP, bestHum
end

-- ===== NEAREST MOB FARM (Hard Trial) – AKILLI RESET =====
local function findNearestHumanoid()
    local char = LP.Character
    if not char then return nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end

    if not isInHardTrial() then
        return nil
    end

    local st = TrialState.Hard
    local nearest = nil
    local nearestDist = math.huge

    local gc = WS:FindFirstChild("__GAME_CONTENT")
    if gc then
        local mobsFolder = gc:FindFirstChild("Mobs")
        if mobsFolder then
            for _, mob in ipairs(mobsFolder:GetChildren()) do
                if mob:IsA("Model") and mob ~= char then
                    if st.visitedMobs[mob] then continue end
                    local hum = nil
                    for _, d in ipairs(mob:GetDescendants()) do
                        if d:IsA("Humanoid") and d.Health > 0 then
                            hum = d; break
                        end
                    end
                    if not hum then continue end
                    local mobHRP = mob:FindFirstChild("HumanoidRootPart")
                    if not mobHRP then
                        for _, d in ipairs(mob:GetDescendants()) do
                            if d:IsA("BasePart") and d.Name == "HumanoidRootPart" then mobHRP = d; break end
                        end
                    end
                    if mobHRP then
                        local mobDistToTrial = (mobHRP.Position - Trials.Hard.coord).Magnitude
                        if mobDistToTrial > 200 then continue end
                        local dist = (hrp.Position - mobHRP.Position).Magnitude
                        if dist < nearestDist and dist > 5 then
                            nearestDist = dist
                            nearest = mob
                        end
                    end
                end
            end
        end
    end

    if not nearest then
        for _, obj in ipairs(WS:GetDescendants()) do
            if obj:IsA("Humanoid") and obj.Health > 0 then
                local mob = obj.Parent
                if mob and mob:IsA("Model") and mob ~= char then
                    if st.visitedMobs[mob] then continue end
                    local mobHRP = mob:FindFirstChild("HumanoidRootPart")
                    if mobHRP then
                        local mobDistToTrial = (mobHRP.Position - Trials.Hard.coord).Magnitude
                        if mobDistToTrial > 200 then continue end
                        local dist = (hrp.Position - mobHRP.Position).Magnitude
                        if dist < nearestDist and dist > 5 then
                            nearestDist = dist
                            nearest = mob
                        end
                    end
                end
            end
        end
    end

    return nearest
end

local function nearestMobFarmLoop()
    local st = TrialState.Hard
    local lastMobFound = tick()
    local lastWave = 0

    while st.nearestMobFarm and not env.NIStop and not st.nearestStopFlag do
        if S.trialActive then task.wait(0.3); continue end

        -- Trial içinde mi?
        if not isInHardTrial() then
            task.wait(1)
            continue
        end

        -- Wave oku
        local currentWave = getWaveCount() or 0

        -- Eğer wave değiştiyse ve 0'dan büyükse reset at
        if currentWave ~= lastWave and currentWave > 0 then
            st.visitedMobs = {}
            st.mobCount = 0
            lastWave = currentWave
            print("[NEAREST] Wave changed to " .. currentWave .. ", resetting list")
            if activeTween then pcall(function() activeTween:Cancel() end); activeTween = nil end
            task.wait(0.3)
            continue
        end
        lastWave = currentWave

        -- Wave'i state'e kaydet (auto leave için)
        if currentWave > 0 then
            st.wave = currentWave
        end

        -- Auto Leave kontrolü
        if st.autoLeave and st.leaveWave > 0 and st.wave >= st.leaveWave then
            print("[AUTO LEAVE] Leaving Hard trial at wave " .. st.wave)
            pcall(function() game:GetService("ReplicatedStorage").__Net.MainRemote:FireServer("LeaveTrial") end)
            st.wave = 1; st.mobCount = 0; st.visitedMobs = {}; st.inTrial = false
            S.trialActive = false

            -- 2-3 saniye sonra captured position'a dön
            if st.autoReturn and st.capturedPos then
                task.delay(2.5, function()
                    print("[RETURN] Returning to captured position...")
                    teleportTo(st.capturedPos)
                end)
            end

            if S.autoCapsuleAfterTrial then task.delay(3, fireToggleCapsule) end
            break
        end

        -- En yakın mobu bul
        local mob = findNearestHumanoid()
        if not mob then
            -- 1 saniye mob bulamazsa reset (15'ten 1'e düşürüldü)
            if tick() - lastMobFound > 1 then
                st.visitedMobs = {}
                st.mobCount = 0
                lastMobFound = tick()
                print("[NEAREST] No mobs for 1s, resetting list")
                if activeTween then pcall(function() activeTween:Cancel() end); activeTween = nil end
            end
            task.wait(1)
            continue
        end
        lastMobFound = tick()

        -- Ziyaret et
        st.visitedMobs[mob] = true
        st.mobCount = st.mobCount + 1
        if st.mobCount >= 7 then
            st.visitedMobs = {}
            st.mobCount = 0
        end

        local mobHRP = mob:FindFirstChild("HumanoidRootPart")
        if not mobHRP then
            for _, d in ipairs(mob:GetDescendants()) do
                if d:IsA("BasePart") and d.Name == "HumanoidRootPart" then mobHRP = d; break end
            end
        end
        if not mobHRP then task.wait(0.5); continue end

        -- Mob'a git
        tweenTo(mobHRP.Position, S.nearestSpeed)

        -- Saldır
        local tool = LP.Character and LP.Character:FindFirstChildOfClass("Tool")
        if tool then
            for i = 1, 5 do
                if not st.nearestMobFarm or env.NIStop or st.nearestStopFlag or S.trialActive then break end
                pcall(function() tool:Activate(); tool:Deactivate() end)
                task.wait(0.1)
            end
        end

        task.wait(0.5)
    end
    st.nearestLoopThread = nil
end

local function startNearestMobFarm()
    local st = TrialState.Hard
    if st.nearestLoopThread then return end
    st.nearestStopFlag = false
    st.nearestLoopThread = task.spawn(nearestMobFarmLoop)
end

local function stopNearestMobFarm()
    local st = TrialState.Hard
    if st.nearestLoopThread then
        st.nearestStopFlag = true
        if activeTween then
            pcall(function() activeTween:Cancel() end)
            activeTween = nil
        end
        task.wait(0.1)
        st.nearestLoopThread = nil
    end
end

