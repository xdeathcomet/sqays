-- ===== GRIND + WAVE + LEAVE (Hard için getWaveCount kullanır) =====
for diff, data in pairs(Trials) do
    local st = TrialState[diff]
    task.spawn(function()
        while not env.NIStop do
            if not st.walk then task.wait(0.2); continue end
            local ok, err = pcall(function()
                local char = LP.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                if not hrp then task.wait(0.05); return end

                if diff == "Hard" then
                    local w = getWaveCount()
                    if w and w ~= st.wave then
                        st.wave = w
                        print("[HARD WAVE] Wave " .. st.wave)
                    end
                    if st.autoLeave and st.leaveWave > 0 and st.wave >= st.leaveWave then
                        print("[AUTO LEAVE] Leaving Hard trial at wave " .. st.wave)
                        pcall(function() game:GetService("ReplicatedStorage").__Net.MainRemote:FireServer("LeaveTrial") end)
                        st.wave = 1; st.prevCount = -1; st.inTrial = false
                        S.trialActive = false

                        if st.autoReturn and st.capturedPos then
                            task.delay(2.5, function()
                                print("[RETURN] Returning to captured position...")
                                teleportTo(st.capturedPos)
                            end)
                        end

                        if S.autoCapsuleAfterTrial then task.delay(3, fireToggleCapsule) end
                        return
                    end
                end

                local room = WS:FindFirstChild("__GAME_CONTENT") and WS.__GAME_CONTENT:FindFirstChild("Trials") and WS.__GAME_CONTENT.Trials:FindFirstChild(data.room)
                if not room then
                    local trialsFolder = WS:FindFirstChild("__GAME_CONTENT") and WS.__GAME_CONTENT:FindFirstChild("Trials")
                    if trialsFolder then
                        for _, child in ipairs(trialsFolder:GetChildren()) do
                            if child:IsA("Model") and (child.Name:lower():find(diff:lower()) or child.Name:lower():find("trial")) then
                                room = child; break
                            end
                        end
                    end
                end
                if not room then task.wait(0.1); return end

                if diff ~= "Hard" then
                    local alive = 0
                    local mobsFolder = room:FindFirstChild("Mobs")
                    if mobsFolder then
                        for _, v in ipairs(mobsFolder:GetDescendants()) do
                            if v:IsA("Humanoid") and v.Health > 0 and v.Parent ~= char then alive = alive + 1 end
                        end
                    end
                    if st.prevCount > 0 and alive == 0 then
                        st.wave = st.wave + 1
                        print("["..diff.." WAVE] Wave "..st.wave)
                        if st.autoLeave and st.leaveWave > 0 and st.wave >= st.leaveWave then
                            print("[AUTO LEAVE] Leaving "..diff.." trial at wave "..st.wave)
                            pcall(function() game:GetService("ReplicatedStorage").__Net.MainRemote:FireServer("LeaveTrial") end)
                            st.wave = 1; st.prevCount = -1; st.inTrial = false
                            S.trialActive = false

                            if st.autoReturn and st.capturedPos then
                                task.delay(2.5, function()
                                    print("[RETURN] Returning to captured position...")
                                    teleportTo(st.capturedPos)
                                end)
                            end

                            if S.autoCapsuleAfterTrial then task.delay(3, fireToggleCapsule) end
                            return
                        end
                    end
                    st.prevCount = alive
                    if alive == 0 then task.wait(0.1); return end
                end

                local mob, mobHRP, mobHum = findTrialMob(room)
                if not mob then task.wait(0.05); return end
                while mob and st.walk and not env.NIStop do
                    local mobPos = mobHRP and mobHRP.Position
                    if not mobPos then mobPos = getMobPosition(mob) end
                    if mobPos and not isCloseEnough(hrp, mobPos, 5) then
                        glideTo(mobPos, 0.15)
                    end
                    local deathStart = tick()
                    while st.walk and mob and not env.NIStop do
                        local dead = false
                        pcall(function()
                            if not mobHum or mobHum.Health <= 0 or not mobHum.Parent then dead = true end
                        end)
                        if dead then break end
                        if not mob.Parent then break end
                        if tick() - deathStart > 5 then break end
                        RS.Heartbeat:Wait()
                    end
                    local prevMob = mob
                    pcall(function() mob, mobHRP, mobHum = findTrialMob(room) end)
                    if mob == prevMob then
                        pcall(function() mob, mobHRP, mobHum = findTrialMob(room) end)
                        if mob == prevMob then mob = nil end
                    end
                end
            end)
            if not ok then warn("[GRIND "..diff.." ERROR] " .. tostring(err)) end
        end
    end)
end

