local function ancientBossLoop()
    while S.abossRunning and not env.NIStop do
        if not hasAncientFragment() then S.abossStatus = "No Fragment"; task.wait(10); continue end
        local boss = findAncientBossInstance()
        if boss then
            S.abossStatus = "Attacking..."
            local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local pos = getMobPosition(boss)
                if pos and (hrp.Position - pos).Magnitude > 6 then tweenTo(pos, S.combatTweenSpeed) end
                local start = tick()
                while S.abossRunning and not env.NIStop and tick() - start < 120 do
                    if not isMobAlive(boss) then S.abossStatus = "Defeated!"; break end
                    local tool = LP.Character and LP.Character:FindFirstChildOfClass("Tool")
                    if tool then pcall(function() tool:Activate(); tool:Deactivate() end) end
                    task.wait(0.05)
                end
            end
        else
            S.abossStatus = "Spawning..."
            spawnAncientBoss()
            task.wait(5)
        end
    end
    S.abossStatus = "Stopped"
end

